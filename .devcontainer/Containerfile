FROM quay.io/fedora/fedora:43@sha256:49d23fddd505205c56d10c2e7400d92fbd4b2311b5d7d0856fe633879ce5cf67

ENV UV_LINK_MODE=copy
ENV UV_COMPILE_BYTECODE=1
ENV SHELL=/usr/bin/fish

RUN dnf install -y \
    python3 \
    python3-pip \
    git \
    make \
    fish \
    sudo \
    && dnf clean all

COPY --from=ghcr.io/astral-sh/uv:latest@sha256:1e3808aa9023d0980e7c15b1fa7c1ac16ff35925780cf5c459858b2d693f01a9 /uv /usr/local/bin/uv

# Create vscode user with sudo access and fish shell
RUN useradd -m -s /usr/bin/fish vscode && \
    echo "vscode ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers.d/vscode

WORKDIR /workspace
